{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/schemas/pending_interaction.resolve.v0.1.0.schema.json",
  "title": "Pending Interaction Resolve Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "run_id",
    "thread_id",
    "interaction_id",
    "surface_id",
    "payload"
  ],
  "properties": {
    "type": {
      "const": "pending_interaction.resolve"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "interaction_id": {
      "type": "string",
      "minLength": 1
    },
    "surface_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_product_ids"],
      "properties": {
        "selected_product_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
